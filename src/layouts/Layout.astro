---
import generateUrl from "@utils/url";

interface Props {
  title: string;
  description?: string;
  image?: string;
  noindex?: boolean;
}

const {
  title,
  description = "Fabien Salles - Je vous aide à produire des applications pérennes",
  image = "/fabiensalles.webp",
  noindex = false
} = Astro.props;

const ogImage = new URL(image, Astro.site).href;

const currentPath = Astro.url.pathname;
const isEnglishPath = currentPath.startsWith('/en');

// Helper to check if a nav item is active
const isActive = (href: string) => {
  // Exact match
  if (currentPath === href || currentPath === href + '/') return true;
  // For formations, also match sub-pages
  if (href === '/formations' && currentPath.startsWith('/formations/')) return true;
  return false;
};
const translationEnabled = import.meta.env.TRANSLATION_ENABLED === 'true';
const trainingEnabled = import.meta.env.TRAINING_ENABLED === 'true';
const contactEnabled = import.meta.env.CONTACT_ENABLED === 'true';
const aboutEnabled = import.meta.env.ABOUT_ENABLED === 'true';
const cvEnabled = import.meta.env.CV_ENABLED === 'true';
const googleAnalyticsId = import.meta.env.GOOGLE_ANALYTICS_ID;

const routeMapping = {
  '/formations': '/en/training',
  '/en/training': '/formations',
  '/cv': '/en/resume',
  '/en/resume': '/cv',
  '/about': '/en/about',
  '/en/about': '/about',
  '/blog': '/en/blog',
  '/en/blog': '/blog',
  '/contact': '/en/contact',
  '/en/contact': '/contact',
  '/': '/en',
  '/en': '/',
};

let alternateLink = routeMapping[currentPath];

if (!alternateLink) {
  if (currentPath.startsWith('/blog/')) {
    alternateLink = '/en' + currentPath;
  } else if (currentPath.startsWith('/en/blog/')) {
    alternateLink = currentPath.replace('/en', '');
  }
}

---

<!doctype html>
<html lang={isEnglishPath ? 'en' : 'fr'}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, follow" />}
    <meta name="author" content="Fabien Salles" />
    <meta name="keywords" content="Software craftsmanship, craft, architecture, test, TDD, DDD, legacy, refactoring, tech lead, technical coach, trainer, formateur, phpunit, artisanat, architecture hexagonal, BDD, clean architecture, PHP, Nodejs, Symfony" />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:image" content={ogImage} />
    <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site).href} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="alternate" type="application/rss+xml" title="Fabien Salles - Blog RSS Feed" href={generateUrl('/rss.xml')} />
    <script is:inline type="text/partytown" src=`https://www.googletagmanager.com/gtag/js?id=${googleAnalyticsId}`>
    </script>
    <script is:inline type="text/partytown" define:vars={{googleAnalyticsId}}>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag("js", new Date());
      gtag("config", googleAnalyticsId);
    </script>
    <script is:inline type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "Person",
          "@id": "https://fabiensalles.com/#person",
          "name": "Fabien Salles",
          "url": "https://fabiensalles.com",
          "image": "https://fabiensalles.com/fabiensalles.webp",
          "jobTitle": "Expert Software Craftsmanship",
          "description": "Expert DDD, TDD & Software Craftsmanship. Accompagnement, audit de code, formations PHP/Symfony.",
          "sameAs": [
            "https://www.linkedin.com/in/fabiensalles/",
            "https://github.com/fabiensalles"
          ],
          "knowsAbout": ["DDD", "TDD", "Software Craftsmanship", "PHP", "Symfony", "Clean Architecture"]
        },
        {
          "@type": "WebSite",
          "@id": "https://fabiensalles.com/#website",
          "url": "https://fabiensalles.com",
          "name": "Fabien Salles",
          "publisher": { "@id": "https://fabiensalles.com/#person" }
        },
        {
          "@type": "SiteNavigationElement",
          "name": "Navigation principale",
          "hasPart": [
            { "@type": "WebPage", "name": "Accompagnement", "url": "https://fabiensalles.com/accompagnement/" },
            { "@type": "WebPage", "name": "Audit", "url": "https://fabiensalles.com/audit/" },
            { "@type": "WebPage", "name": "Formations", "url": "https://fabiensalles.com/formations/" },
            { "@type": "WebPage", "name": "Automatisation", "url": "https://fabiensalles.com/automatisation/" },
            { "@type": "WebPage", "name": "Blog", "url": "https://fabiensalles.com/blog/" },
            { "@type": "WebPage", "name": "Contact", "url": "https://fabiensalles.com/contact/" }
          ]
        }
      ]
    }
    </script>
  </head>
  <body class="min-h-screen bg-surface">
    <header class="fixed w-full bg-surface border-b-2 border-primary z-50">
      <nav class="container mx-auto px-4 py-4">
        <div class="flex items-center justify-between">
          <a
            href={isEnglishPath ? '/en' : '/'}
            title="Accueil"
            class="text-xl font-semibold text-foreground-heading hover:text-primary transition-colors"
            data-astro-reload
          >
            Fabien Salles
          </a>

          <!-- Mobile menu button -->
          <button
            id="mobile-menu-button"
            class="md:hidden text-foreground-heading p-2 focus:outline-none"
            aria-label="Menu"
          >
            <svg id="menu-icon-open" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
            </svg>
            <svg id="menu-icon-close" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
            </svg>
          </button>

          <!-- Desktop menu -->
          <ul class="hidden md:flex gap-6 items-center">
            <li><a href="/accompagnement" class={isActive('/accompagnement') ? 'nav-link-active' : 'nav-link'} data-astro-reload>Accompagnement</a></li>
            <li><a href="/audit" class={isActive('/audit') ? 'nav-link-active' : 'nav-link'} data-astro-reload>Audit</a></li>
            {
              trainingEnabled &&
              <li id="formations-nav" class="static">
                <a href={isEnglishPath ? '/en/training' : '/formations'} class={`${isActive('/formations') ? 'nav-link-active' : 'nav-link'} inline-flex items-center gap-1 leading-none`} data-astro-reload>
                  {isEnglishPath ? 'Training' : 'Formations'}
                  <svg id="formations-chevron" class="w-2.5 h-2.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"></path></svg>
                </a>
              </li>
            }
            <li><a href="/automatisation" class={isActive('/automatisation') ? 'nav-link-active' : 'nav-link'} data-astro-reload>Automatisation</a></li>
            <li><a href="/apport-affaires" class={isActive('/apport-affaires') ? 'nav-link-active' : 'nav-link'} data-astro-reload>Apport d'affaires</a></li>
            <li><a href={generateUrl('/blog')} title="Blog" class={isActive('/blog') ? 'nav-link-active' : 'nav-link'} data-astro-reload>Blog</a></li>
            {
              cvEnabled &&
              <li><a href={isEnglishPath ? '/en/resume' : '/cv'} class={isActive('/cv') ? 'nav-link-active' : 'nav-link'} data-astro-reload>{isEnglishPath ? 'Resume' : 'CV'}</a></li>
            }
            {
              aboutEnabled &&
              <li><a href={isEnglishPath ? '/en/about' : '/about'} class={isActive('/about') ? 'nav-link-active' : 'nav-link'} data-astro-reload>{isEnglishPath ? 'About' : 'À propos'}</a></li>
            }
            {
              contactEnabled &&
              <li><a href={isEnglishPath ? '/en/contact' : '/contact'} class={isActive('/contact') ? 'nav-link-active' : 'nav-link'} data-astro-reload>Contact</a></li>
            }
            {
              translationEnabled &&
                <li>
                  <a
                    href={isEnglishPath ? '/' : '/en'}
                    class="lang-switch"
                    data-astro-reload
                  >
                    {isEnglishPath ? 'FR' : 'EN'}
                  </a>
                </li>
            }
          </ul>
        </div>

        <!-- Mobile menu -->
        <ul id="mobile-menu" class="hidden md:hidden flex-col gap-1 pt-4 pb-2">
          <li><a href="/accompagnement" class={`block py-2 px-3 rounded-lg ${isActive('/accompagnement') ? 'nav-link-active' : 'nav-link'}`} data-astro-reload>Accompagnement</a></li>
          <li><a href="/audit" class={`block py-2 px-3 rounded-lg ${isActive('/audit') ? 'nav-link-active' : 'nav-link'}`} data-astro-reload>Audit</a></li>
          {
            trainingEnabled &&
            <li>
              <a href={isEnglishPath ? '/en/training' : '/formations'} class={`block py-2 px-3 rounded-lg ${isActive('/formations') ? 'nav-link-active' : 'nav-link'}`} data-astro-reload>{isEnglishPath ? 'Training' : 'Formations'}</a>
              <ul class="pl-4 flex flex-col gap-1 mt-1">
                <li><a href="/formations/git" class={`block py-1.5 px-3 rounded-lg text-sm transition-colors ${isActive('/formations/git') ? 'nav-link-sub-active text-foreground-heading font-medium' : 'text-foreground-muted hover:text-primary'}`} data-astro-reload>Git</a></li>
                <li><a href="/formations/phpunit" class={`block py-1.5 px-3 rounded-lg text-sm transition-colors ${isActive('/formations/phpunit') ? 'nav-link-sub-active text-foreground-heading font-medium' : 'text-foreground-muted hover:text-primary'}`} data-astro-reload>PHPUnit</a></li>
                <li><a href="/formations/ddd" class={`block py-1.5 px-3 rounded-lg text-sm transition-colors ${isActive('/formations/ddd') ? 'nav-link-sub-active text-foreground-heading font-medium' : 'text-foreground-muted hover:text-primary'}`} data-astro-reload>DDD</a></li>
              </ul>
            </li>
          }
          <li><a href="/automatisation" class={`block py-2 px-3 rounded-lg ${isActive('/automatisation') ? 'nav-link-active' : 'nav-link'}`} data-astro-reload>Automatisation</a></li>
          <li><a href="/apport-affaires" class={`block py-2 px-3 rounded-lg ${isActive('/apport-affaires') ? 'nav-link-active' : 'nav-link'}`} data-astro-reload>Apport d'affaires</a></li>
          <li><a href={generateUrl('/blog')} class={`block py-2 px-3 rounded-lg ${isActive('/blog') ? 'nav-link-active' : 'nav-link'}`} data-astro-reload>Blog</a></li>
          {
            cvEnabled &&
            <li><a href={isEnglishPath ? '/en/resume' : '/cv'} class={`block py-2 px-3 rounded-lg ${isActive('/cv') ? 'nav-link-active' : 'nav-link'}`} data-astro-reload>{isEnglishPath ? 'Resume' : 'CV'}</a></li>
          }
          {
            aboutEnabled &&
            <li><a href={isEnglishPath ? '/en/about' : '/about'} class={`block py-2 px-3 rounded-lg ${isActive('/about') ? 'nav-link-active' : 'nav-link'}`} data-astro-reload>{isEnglishPath ? 'About' : 'À propos'}</a></li>
          }
          {
            contactEnabled &&
            <li><a href={isEnglishPath ? '/en/contact' : '/contact'} class={`block py-2 px-3 rounded-lg ${isActive('/contact') ? 'nav-link-active' : 'nav-link'}`} data-astro-reload>Contact</a></li>
          }
          {
            translationEnabled &&
              <li>
                <a
                  href={isEnglishPath ? '/' : '/en'}
                  class="block lang-switch py-2 px-3"
                  data-astro-reload
                >
                  {isEnglishPath ? 'FR' : 'EN'}
                </a>
              </li>
          }
        </ul>
      </nav>

      <!-- Mega menu formations (pleine largeur) -->
      {trainingEnabled &&
        <div id="formations-mega" class="hidden bg-white border-t border-border-light">
          <div class="container mx-auto px-4 py-8">
            <div class="grid grid-cols-3 gap-8 max-w-5xl mx-auto">
              <a href="/formations/git" class={`block p-5 rounded-lg hover:bg-surface border transition-all ${currentPath.startsWith('/formations/git') ? 'border-border-light bg-surface' : 'border-transparent hover:border-border-light'}`} data-astro-reload>
                <div class="flex items-center justify-between mb-2">
                  <span class="font-bold text-foreground-heading">Git avancé</span>
                  <span class="text-xs text-foreground-muted bg-surface px-2 py-0.5 rounded-full">2 jours</span>
                </div>
                <p class="text-sm text-foreground mb-2">Tu utilises Git tous les jours mais tu ne le comprends pas vraiment ?</p>
                <p class="text-sm text-foreground-muted italic">Passe de "ça marche je sais pas pourquoi" à "je sais exactement ce que je fais".</p>
                <span class="inline-block mt-3 text-sm text-primary font-medium">Découvrir →</span>
              </a>
              <a href="/formations/phpunit" class={`block p-5 rounded-lg hover:bg-surface border transition-all ${currentPath.startsWith('/formations/phpunit') ? 'border-border-light bg-surface' : 'border-transparent hover:border-border-light'}`} data-astro-reload>
                <div class="flex items-center justify-between mb-2">
                  <span class="font-bold text-foreground-heading">PHPUnit</span>
                  <span class="text-xs text-foreground-muted bg-surface px-2 py-0.5 rounded-full">2 jours</span>
                </div>
                <p class="text-sm text-foreground mb-2">Tes tests cassent sans raison ? Ils prennent trop de temps à écrire et à maintenir ?</p>
                <p class="text-sm text-foreground-muted italic">Apprends à écrire des tests qui te font gagner du temps au lieu d'en perdre.</p>
                <span class="inline-block mt-3 text-sm text-primary font-medium">Découvrir →</span>
              </a>
              <a href="/formations/ddd" class={`block p-5 rounded-lg hover:bg-surface border transition-all ${currentPath.startsWith('/formations/ddd') ? 'border-border-light bg-surface' : 'border-transparent hover:border-border-light'}`} data-astro-reload>
                <div class="flex items-center justify-between mb-2">
                  <span class="font-bold text-foreground-heading">DDD</span>
                  <span class="text-xs text-foreground-muted bg-surface px-2 py-0.5 rounded-full">3 à 5 jours</span>
                </div>
                <p class="text-sm text-foreground mb-2">Le métier et la tech ne se comprennent pas ? Le couplage crée des régressions ?</p>
                <p class="text-sm text-foreground-muted italic">Aligne ton équipe technique et produit pour livrer ce qui compte vraiment.</p>
                <span class="inline-block mt-3 text-sm text-primary font-medium">Découvrir →</span>
              </a>
            </div>
            <div class="flex items-center justify-center gap-6 mt-6 pt-4 border-t border-border-light max-w-5xl mx-auto">
              <span class="text-sm text-foreground-muted">Organisme déclaré · 137+ développeurs formés · Depuis 2016</span>
              <a href="/formations" class="text-sm text-primary hover:text-primary-hover font-medium transition-colors" data-astro-reload>Toutes les formations →</a>
            </div>
          </div>
        </div>
      }
    </header>

    <script>
      const mobileMenuButton = document.getElementById('mobile-menu-button');
      const mobileMenu = document.getElementById('mobile-menu');
      const menuIconOpen = document.getElementById('menu-icon-open');
      const menuIconClose = document.getElementById('menu-icon-close');

      mobileMenuButton?.addEventListener('click', () => {
        mobileMenu?.classList.toggle('hidden');
        mobileMenu?.classList.toggle('flex');
        menuIconOpen?.classList.toggle('hidden');
        menuIconClose?.classList.toggle('hidden');
      });

      // Mega menu formations
      const formationsNav = document.getElementById('formations-nav');
      const formationsMega = document.getElementById('formations-mega');
      const formationsChevron = document.getElementById('formations-chevron');
      let hideTimeout: ReturnType<typeof setTimeout>;

      function showMega() {
        clearTimeout(hideTimeout);
        formationsMega?.classList.remove('hidden');
        formationsChevron?.classList.add('rotate-180');
      }

      function hideMega() {
        hideTimeout = setTimeout(() => {
          formationsMega?.classList.add('hidden');
          formationsChevron?.classList.remove('rotate-180');
        }, 150);
      }

      formationsNav?.addEventListener('mouseenter', showMega);
      formationsNav?.addEventListener('mouseleave', hideMega);
      formationsMega?.addEventListener('mouseenter', showMega);
      formationsMega?.addEventListener('mouseleave', hideMega);
    </script>

    <main class="pt-20 relative">
      <slot />
    </main>

    <footer class="py-8 bg-surface border-t border-primary">
      <div class="container mx-auto px-4">
        <div class="flex justify-between items-center">
          <p class="text-foreground-muted">&copy; {new Date().getFullYear()} Fabien Salles</p>
          <div class="flex gap-4">
            <a
              href="https://www.linkedin.com/in/fabiensalles/"
              target="_blank"
              title="Linkedin Fabien Salles"
              rel="noopener noreferrer"
              class="social-link"
            >
              LinkedIn
            </a>
            {
              contactEnabled &&
              <a href="/contact" class="social-link">
                  Contact
              </a>
            }
            <a href={generateUrl('/rss.xml')} class="social-link" title="RSS Feed">
              RSS
            </a>
          </div>
        </div>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  html {
    scroll-behavior: smooth;
  }

  /* Button styles */
  .btn-primary {
    @apply inline-flex items-center justify-center bg-primary-cta text-white px-6 py-3 rounded-lg font-bold hover:bg-primary-cta-hover transition-colors;
  }

  .btn-outline {
    @apply inline-flex items-center justify-center border-2 border-primary-cta text-primary-cta px-6 py-3 rounded-lg font-bold hover:border-primary-cta-hover hover:text-primary-cta-hover hover:bg-surface-muted transition-colors;
  }

  .btn-light {
    @apply inline-flex items-center justify-center bg-white text-primary-dark px-8 py-4 rounded-lg font-bold hover:bg-surface-muted transition-colors;
  }

  .btn-ghost {
    @apply inline-flex items-center justify-center bg-white/10 text-white border-2 border-white/30 px-6 py-4 rounded-lg font-bold hover:bg-white/20 transition-colors;
  }

  /* Card styles */
  .card {
    @apply bg-white p-6 rounded-lg border border-border;
  }

  .card-elevated {
    @apply bg-white p-6 rounded-lg border border-border-light;
  }

  /* Badge */
  .badge-status {
    @apply px-3 py-1 bg-green-100 text-green-800 rounded-full text-sm font-bold;
  }

  /* Navigation styles */
  .nav-link {
    @apply relative text-foreground hover:text-foreground-heading transition-colors duration-300;
  }

  .nav-link::after {
    content: '';
    @apply absolute left-0 -bottom-2 w-0 h-0.5 bg-primary transition-all duration-300;
  }

  .nav-link:hover::after {
    @apply w-full;
  }

  /* Active navigation state */
  .nav-link-active {
    @apply relative text-foreground-heading font-medium transition-colors duration-300;
  }

  .nav-link-active::after {
    content: '';
    @apply absolute left-0 -bottom-2 w-full h-0.5 bg-foreground-heading;
  }

  /* Mobile: fond pleine largeur au lieu du underline */
  @media (max-width: 767px) {
    .nav-link-active {
      @apply bg-surface-muted rounded-lg;
    }
    .nav-link-active::after {
      @apply hidden;
    }
    .nav-link-sub-active {
      @apply bg-surface-muted rounded-lg;
    }
  }

  /* Language switch */
  .lang-switch {
    @apply relative px-4 py-2 text-sm font-medium text-foreground rounded-lg transition-all duration-300 hover:bg-surface;
  }

  /* Social link styles */
  .social-link {
    @apply relative text-foreground-muted hover:text-primary transition-colors duration-300;
  }

  .social-link::after {
    content: '';
    @apply absolute left-0 bottom-0 w-0 h-0.5 bg-primary transition-all duration-300;
  }

  .social-link:hover::after {
    @apply w-full;
  }

  /* Form styles */
  .form-input,
  .form-select,
  .form-textarea {
    @apply w-full px-4 py-3 rounded-lg border border-border
           focus:ring-2 focus:ring-primary focus:border-primary
           bg-white transition-all duration-300;
  }

  p img {
    @apply block mx-auto;
  }

  .image-source {
      @apply text-xs text-foreground-muted italic;
  }
</style>
