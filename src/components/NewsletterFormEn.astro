---
---

<div class="bg-surface border border-border-light rounded-xl p-8 my-12">
  <div class="max-w-2xl mx-auto text-center">
    <h3 class="text-2xl font-bold mb-4">Stay Informed</h3>
    <p class="text-foreground-muted mb-6">
      Subscribe to my newsletter to receive my latest articles and updates about software craftsmanship.
    </p>
    <form class="flex flex-col sm:flex-row gap-4 max-w-md mx-auto">
      <input
        type="email"
        placeholder="Your email address"
        class="flex-1 px-4 py-2 rounded-lg border border-border focus:ring-2 focus:ring-primary focus:border-primary"
        required
      />
      <button
        type="submit"
        class="bg-primary-cta text-white px-6 py-2 rounded-lg hover:bg-primary-cta-hover transition-colors duration-300"
      >
        Subscribe
      </button>
    </form>
    <p class="text-sm text-foreground-muted mt-4">
      You can unsubscribe at any time. No spam, promise!
    </p>
  </div>
</div>