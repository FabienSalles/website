---
import { getEntry } from 'astro:content';
import Layout from '../layouts/Layout.astro';

const cv = await getEntry('cv', 'cv');
const { data } = cv;
---

<Layout title={data.title} description={data.description}>
  <div class="container mx-auto px-4 py-12">
    <header class="mb-12">
      <h1 class="text-4xl font-bold mb-4">{data.title}</h1>
      <p class="text-xl text-foreground">{data.description}</p>
    </header>

    <section class="mb-12">
      <h2 class="text-2xl font-bold mb-6">Expériences professionnelles</h2>
      <div class="space-y-8">
        {data.experiences.map((exp) => (
          <div class="border-l-4 border-primary pl-4 hover:bg-surface transition-colors rounded-r-lg">
            <div class="flex justify-between items-start mb-2">
              <div>
                <h3 class="text-xl font-semibold">{exp.title}</h3>
                <p class="text-foreground">{exp.company} • {exp.location}</p>
              </div>
              <div class="text-foreground-muted">
                <time datetime={exp.startDate.toISOString()}>
                  {exp.startDate.toLocaleDateString('fr-FR', { month: 'long', year: 'numeric' })}
                </time>
                {exp.endDate ? (
                  <>
                    {' - '}
                    <time datetime={exp.endDate.toISOString()}>
                      {exp.endDate.toLocaleDateString('fr-FR', { month: 'long', year: 'numeric' })}
                    </time>
                  </>
                ) : ' - Présent'}
              </div>
            </div>
            <p class="text-foreground mb-3">{exp.description}</p>
            <div class="mb-3">
              <h4 class="font-semibold mb-2">Réalisations :</h4>
              <ul class="list-disc list-inside space-y-1 text-foreground">
                {exp.achievements.map((achievement) => (
                  <li>{achievement}</li>
                ))}
              </ul>
            </div>
            <div class="flex flex-wrap gap-2">
              {exp.technologies.map((tech) => (
                <span class="px-3 py-1 bg-surface-muted rounded-full text-sm hover:bg-surface-muted transition-colors">
                  {tech}
                </span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>

    <section class="mb-12">
      <h2 class="text-2xl font-bold mb-6">Compétences</h2>
      <div class="grid md:grid-cols-2 gap-6">
        {data.skills.map((skillGroup) => (
          <div class="p-6 border rounded-lg hover:border-primary transition-colors">
            <h3 class="text-xl font-semibold mb-3">{skillGroup.category}</h3>
            <div class="flex flex-wrap gap-2">
              {skillGroup.items.map((skill) => (
                <span class="px-3 py-1 bg-surface-muted rounded-full text-sm hover:bg-surface-muted transition-colors">
                  {skill}
                </span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>

    <section class="mb-12">
      <h2 class="text-2xl font-bold mb-6">Formation</h2>
      <div class="space-y-6">
        {data.education.map((edu) => (
          <div class="p-6 border rounded-lg hover:border-primary transition-colors">
            <div class="flex justify-between items-start">
              <div>
                <h3 class="text-xl font-semibold">{edu.degree}</h3>
                <p class="text-foreground">{edu.school} • {edu.location}</p>
              </div>
              <div class="text-foreground-muted">{edu.year}</div>
            </div>
            {edu.description && <p class="text-foreground mt-2">{edu.description}</p>}
          </div>
        ))}
      </div>
    </section>

    <section>
      <h2 class="text-2xl font-bold mb-6">Langues</h2>
      <div class="flex gap-8">
        {data.languages.map((lang) => (
          <div class="p-4 border rounded-lg hover:border-primary transition-colors">
            <h3 class="font-semibold">{lang.name}</h3>
            <p class="text-foreground">{lang.level}</p>
          </div>
        ))}
      </div>
    </section>
  </div>
</Layout>