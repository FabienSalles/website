---
import Layout from '../layouts/Layout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import { Icon } from 'astro-icon/components';
---

<Layout
  title="Apport d'affaires - Tu as une mission à proposer ? | Fabien Salles"
  description="Tu as une mission que tu ne peux pas prendre ? Parlons-en. Je serais ravi de collaborer avec toi et de te rémunérer pour cette opportunité."
>
  <div class="container mx-auto px-4 pt-12">
    <Breadcrumb items={[{ label: 'Accueil', href: '/' }, { label: "Apport d'affaires" }]} />
  </div>

  <!-- HERO SECTION — cream (no bg) -->
  <section class="py-16">
    <div class="container mx-auto px-4">
      <div class="text-center">
        <h1 class="text-4xl md:text-5xl font-bold mb-6 leading-tight">
          Tu as une mission à proposer ?
        </h1>
        <p class="text-xl text-foreground-muted max-w-3xl mx-auto mb-8 leading-relaxed">
          Un client te fait confiance mais tu n'es pas dispo ?<br>
          Tu cherches quelqu'un de fiable pour ne pas perdre cette opportunité ?<br>
          <span class="font-medium text-foreground-heading">Parlons-en.</span>
        </p>

        <a
          href="#contact"
          class="btn-primary text-lg"
        >
          On en discute ?
        </a>
      </div>
    </div>
  </section>

  <!-- SECTION CE QUE TU VIS — bg-white -->
  <section class="bg-white py-16">
    <div class="container mx-auto px-4">
      <h2 class="text-2xl font-bold mb-8 text-center">Tu connais peut-être ça</h2>
      <div class="max-w-2xl mx-auto">
        <ul class="space-y-4 text-foreground text-lg">
          <li class="flex items-start gap-3">
            <span class="text-primary mt-1">→</span>
            <span>Tu as un client qui te contacte, mais tu n'es pas disponible</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-primary mt-1">→</span>
            <span>Tu ne veux pas laisser passer l'opportunité, ni recommander n'importe qui</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-primary mt-1">→</span>
            <span>Tu cherches quelqu'un de fiable, qui ne va pas "récupérer" ton client</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-primary mt-1">→</span>
            <span>Tu voudrais garder une bonne relation avec ce client pour plus tard</span>
          </li>
        </ul>
        <p class="text-sm text-foreground-muted mt-8 italic text-center">
          Si tu te reconnais, cette page est pour toi.
        </p>
      </div>
    </div>
  </section>

  <!-- SECTION CE QUE JE PROPOSE — cream (no bg) -->
  <section class="py-16">
    <div class="container mx-auto px-4">
      <h2 class="text-2xl font-bold mb-4 text-center">Ce que je te propose</h2>
      <p class="text-foreground-muted text-center mb-12 max-w-2xl mx-auto">
        Tu fais le lien, je fais le travail. Chacun son rôle.
      </p>

      <div class="max-w-2xl mx-auto">
        <div class="border border-border-light p-8 rounded-xl bg-white">
          <ul class="space-y-4 text-foreground">
            <li class="flex items-start gap-3">
              <span class="text-primary text-xl">✓</span>
              <span>Je prends la mission dans mes domaines d'expertise</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-primary text-xl">✓</span>
              <span>Accompagnement, formations, audits ou développement</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-primary text-xl">✓</span>
              <span>Je livre de la qualité — c'est ta réputation qui est en jeu aussi</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-primary text-xl">✓</span>
              <span>Je ne cherche pas à "récupérer" ton client</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- SECTION PHILOSOPHIE — bg-white -->
  <section class="bg-white py-16">
    <div class="container mx-auto px-4">
      <div class="max-w-3xl mx-auto">
        <h2 class="text-2xl font-bold mb-8 text-center text-foreground-heading">Ce que je veux que tu comprennes</h2>

        <div class="bg-surface rounded-xl p-8 border border-border-light">
          <div class="space-y-6 text-foreground">
            <p class="text-lg font-semibold text-foreground-heading">
              Je préfère travailler et partager la valeur avec celui qui m'a aidé, plutôt que rester les bras croisés à attendre.
            </p>
            <p class="text-lg">
              Si tu me permets de travailler, je serais ravi de te rémunérer pour ça — même si tu ne me demandes rien.
            </p>
            <p class="text-lg font-semibold text-foreground-heading">
              Parce que sans toi, pas de mission. Sans mission, pas de travail. Sans travail, pas d'argent.
            </p>
            <p class="text-lg">
              Je ne fais que redonner la valeur qu'on m'a permis de créer.
            </p>
          </div>

          <div class="mt-8 pt-6 border-t border-border">
            <p class="text-sm font-medium text-foreground-heading mb-2">Concrètement :</p>
            <p class="text-foreground">
              De <span class="font-bold text-primary">0% à 15%</span> selon la mission (courte, longue, réciprocité) — on se met d'accord ensemble.
            </p>
            <p class="text-foreground-muted text-sm mt-2 italic">
              L'important c'est de nouer des relations solides et de se rendre service.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SECTION POURQUOI ME FAIRE CONFIANCE — cream (no bg) -->
  <section class="py-16">
    <div class="container mx-auto px-4">
      <h2 class="text-2xl font-bold mb-8 text-center">Pourquoi me faire confiance</h2>

      <div class="max-w-2xl mx-auto">
        <ul class="space-y-4 text-foreground">
          <li class="flex items-start gap-3">
            <span class="text-primary text-xl">✓</span>
            <span><strong>Je ne fais pas défaut.</strong> Si je m'engage, je vais au bout.</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-primary text-xl">✓</span>
            <span><strong>Je te tiens informé.</strong> Transparence totale sur l'avancement.</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-primary text-xl">✓</span>
            <span><strong>Je livre de la qualité.</strong> Mon objectif : que ton client soit content et que tu puisses lui proposer d'autres choses plus tard.</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-primary text-xl">✓</span>
            <span><strong>Si ça ne matche pas, on se le dit.</strong> Pas de drame. On est entre pros.</span>
          </li>
        </ul>
      </div>
    </div>
  </section>

  <!-- SECTION COMMENT CA MARCHE — bg-white -->
  <section class="bg-white py-16">
    <div class="container mx-auto px-4">
      <h2 class="text-2xl font-bold mb-8 text-center">Comment ça marche</h2>

      <div class="max-w-xl mx-auto">
        <div class="space-y-6">
          <div class="flex gap-4">
            <div class="flex-shrink-0 w-10 h-10 bg-primary text-white rounded-full flex items-center justify-center font-bold text-lg">1</div>
            <div>
              <p class="font-bold text-lg">Tu me contactes</p>
              <p class="text-foreground-muted">Type de mission, contexte, durée. On voit si ça matche.</p>
            </div>
          </div>
          <div class="flex gap-4">
            <div class="flex-shrink-0 w-10 h-10 bg-primary text-white rounded-full flex items-center justify-center font-bold text-lg">2</div>
            <div>
              <p class="font-bold text-lg">On s'accorde</p>
              <p class="text-foreground-muted">Sur la mission et sur ce que tu veux en retour. Pas de surprise.</p>
            </div>
          </div>
          <div class="flex gap-4">
            <div class="flex-shrink-0 w-10 h-10 bg-primary text-white rounded-full flex items-center justify-center font-bold text-lg">3</div>
            <div>
              <p class="font-bold text-lg">Je prends la mission</p>
              <p class="text-foreground-muted">Je te tiens informé. Tu gardes le contact client si tu veux.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SECTION CTA FINALE — cream (no bg) -->
  <section id="contact" class="py-16">
    <div class="container mx-auto px-4">
      <div class="max-w-2xl mx-auto text-center">
        <h2 class="text-3xl md:text-4xl font-bold text-foreground-heading mb-6">Envie d'en discuter ?</h2>
        <p class="text-xl text-foreground-muted mb-8">
          Pas besoin d'un long pitch. Dis-moi juste le type de mission, le contexte, et tes dispos pour en parler.
        </p>

        <div class="flex flex-wrap justify-center gap-4">
          <a
            href="/contact"
            class="btn-primary text-lg"
          >
            Me contacter →
          </a>
          <a
            href="https://www.linkedin.com/in/fabiensalles/"
            target="_blank"
            rel="noopener noreferrer"
            class="btn-outline text-lg inline-flex items-center gap-2"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            LinkedIn
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Tu cherches autre chose ? — bg-white -->
  <section class="bg-white py-16">
    <div class="container mx-auto px-4">
      <div class="max-w-3xl mx-auto text-center">
        <h3 class="text-xl font-bold mb-6">Tu cherches autre chose ?</h3>
        <div class="flex flex-wrap justify-center gap-3 text-sm">
          <a href="/accompagnement" class="inline-flex items-center gap-2 px-3 py-2 bg-surface rounded-lg border border-border-light text-foreground hover:border-primary transition-colors">
            <Icon name="mdi:crosshairs-gps" class="w-5 h-5 text-primary" />
            <span><strong>Accompagnement</strong></span>
          </a>
          <a href="/audit" class="inline-flex items-center gap-2 px-3 py-2 bg-surface rounded-lg border border-border-light text-foreground hover:border-primary transition-colors">
            <Icon name="mdi:magnify" class="w-5 h-5 text-primary" />
            <span><strong>Audit</strong></span>
          </a>
          <a href="/formations" class="inline-flex items-center gap-2 px-3 py-2 bg-surface rounded-lg border border-border-light text-foreground hover:border-primary transition-colors">
            <Icon name="mdi:school" class="w-5 h-5 text-primary" />
            <span><strong>Formations</strong></span>
          </a>
          <a href="/automatisation" class="inline-flex items-center gap-2 px-3 py-2 bg-surface rounded-lg border border-border-light text-foreground hover:border-primary transition-colors">
            <Icon name="mdi:robot" class="w-5 h-5 text-primary" />
            <span><strong>IA & Automatisation</strong></span>
          </a>
        </div>
      </div>
    </div>
  </section>

</Layout>
