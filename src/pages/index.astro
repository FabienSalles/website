  <!-- SERVICE 4: AUTOMATISATION (Style B : fond orange, carte blanche) -->
  <section id="automatisation" class="py-16 bg-orange-900">
    <div class="container mx-auto px-4">
      <div class="max-w-5xl mx-auto">
        <div class="grid md:grid-cols-12 gap-0">
          <!-- Colonne gauche : titre + preuve sociale -->
          <div class="md:col-span-4 md:border-r md:border-white/20 md:pr-8">
            <div class="md:sticky md:top-16">
              <h3 class="text-2xl md:text-3xl font-bold text-white flex items-center gap-3 mb-6">
                <span>Automatiser</span>
