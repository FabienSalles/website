---
import Layout from '../layouts/Layout.astro';
import generateUrl from "@utils/url";
import { Icon } from 'astro-icon/components';
import { getStats } from '../data/formations';

const description = "Expert DDD, TDD & Software Craftsmanship. Audit, accompagnement, formation. J'aide tes équipes à livrer sereinement avec des solutions pensées pour durer."

// Stats dynamiques depuis les données de formations
const formationStats = getStats();

const stats = [
  { number: "15+", label: "années d'expérience" },
  { number: "26+", label: "projets accompagnés" },
  { number: `${formationStats.participants}+`, label: "développeurs formés" },
  { number: `${formationStats.sessions}+`, label: "formations dispensées" }
];

const expertise = [
  "PHP",
  "Symfony",
  "TypeScript",
  "Node.js",
  "TDD",
  "Clean Code",
  "Architecture Hexagonale",
  "DDD",
  "Refactoring",
  "Craftsmanship",
  "IA & Automatisation"
];

const services = [
  {
    icon: "mdi:magnify",
    title: "Auditer",
    intro: "Tu reprends un projet et tu te demandes dans quoi tu mets les pieds ?<br />Tu as des doutes sur la qualité du code avant d'investir ?",
    description: "Je plonge dans le code, je regarde ce qui tient et ce qui va poser problème. PHP, frameworks maison ou standards : Symfony, Sylius, legacy sans framework, ou même des stacks plus anciennes.",
    benefits: [
      "Évaluation de la dette technique",
      "Analyse de l'architecture, pratiques de développement",
      "Rapport détaillé + plan d'action"
    ],
    love: "Ce que j'aime dans l'audit : c'est souvent là que je vois des problèmes que personne n'avait encore identifiés.",
    cta: "En savoir plus",
    href: "/audit"
  },
  {
    icon: "mdi:crosshairs-gps",
    title: "Accompagner",
    intro: "Ton équipe a besoin d'un regard extérieur ?<br />D'un renfort qui ne fait pas que coder ?",
    description: "J'interviens pour améliorer vos pratiques, réduire la dette technique et transmettre les bonnes méthodes.",
    benefits: [
      "Intervention en régie ou au forfait",
      "Amélioration d'un legacy, Refonte progressive",
      "Support et transfert de compétences"
    ],
    love: "Ce que j'aime dans l'accompagnement : voir une équipe gagner en autonomie et en confiance sur son propre code.",
    cta: "En savoir plus",
    href: "/accompagnement"
  },
  {
    icon: "mdi:school",
    title: "Former",
    intro: "Tes devs codent.<br />Mais est-ce qu'ils investissent leur énergie au bon endroit ?",
    description: "Au-delà des aspects techniques, mes formations visent à transformer le mindset : comprendre où investir pour un vrai gain, produire du code qui dure, et arrêter de perdre du temps sur ce qui n'apporte pas de valeur.",
    benefits: [
      "Formations intra-entreprise, distantiel",
      "Organisme déclaré (NDA)",
      `${formationStats.participants}+ développeurs formés depuis 2016`
    ],
    love: "Ce que j'aime dans la formation : voir quelqu'un repartir avec une nouvelle façon de penser, pas juste une nouvelle technique.",
    cta: "Voir les formations",
    href: "/formations"
  },
  {
    icon: "mdi:robot",
    title: "Automatiser",
    intro: "L'IA change notre façon de coder.<br />Mais sans direction, elle amplifie les problèmes autant que les solutions.",
    description: "Je t'aide à intégrer les outils d'automatisation dans tes workflows pour gagner en productivité sans sacrifier la qualité.",
    benefits: [
      "Intégration Claude Code / agents IA",
      "Workflows automatisés",
      "Garde-fous qualité"
    ],
    love: "Ce que j'aime dans l'automatisation : trouver le bon équilibre entre vitesse et garde-fous. Aller vite, mais pas droit dans le mur.",
    cta: "En savoir plus",
    href: "/automatisation"
  }
];

const testimonials = [
  {
    name: "Shahbran Khan GHULAM",
    role: "Ingénieur QA, Hermès",
    content: "Fabien, c'est un vrai pro. Il est extrêmement compétent, toujours pertinent dans ses analyses et redoutablement efficace. Il sait prendre du recul, proposer des solutions intelligentes et faire avancer les choses.",
    image: "/images/recommendations/shahbran-khan-ghulam.webp"
  },
  {
    name: "Jean-Yves Camier",
    role: "DevOps Technical Lead, Bedrock Streaming",
    content: "Sa capacité à rester calme malgré la pression, son ouverture au dialogue, sa curiosité, son amour des choses bien faites font de lui un collaborateur particulièrement important.",
    image: "/images/recommendations/jean-yves-camier.jpg"
  },
  {
    name: "Rodolphe Huot",
    role: "Développeur Web, Hermès",
    content: "Expertise technique pointue dans le développement et le craftsmanship. Toujours force de proposition et à la recherche de l'excellence. Je recommande chaleureusement.",
    image: "/images/recommendations/rodolphe-huot.webp"
  }
];
---

<Layout title="Fabien Salles - Expert DDD, TDD & Software Craftsmanship" description={description}>

  <!-- HERO SECTION -->
  <section class="bg-surface">
    <div class="max-w-5xl mx-auto px-4 py-20 md:py-28">
      <div class="grid md:grid-cols-5 gap-8 items-center">
        <div class="md:col-span-3 text-center md:text-left">
          <p class="text-3xl md:text-4xl font-bold mb-2 leading-tight">
            Salut, je suis Fabien.
          </p>
          <div class="text-primary font-semibold mb-6 flex flex-wrap items-baseline gap-x-2">
            <span>15+ ans d'expérience</span>
            <span>·</span>
            <h1 class="inline text-primary font-semibold text-base md:text-lg">DDD · TDD · Software Craftsmanship</h1>
          </div>
          <p class="text-xl text-foreground-heading font-medium mb-6 leading-relaxed">
            J'aide tes équipes à livrer sereinement, avec des solutions pensées pour durer. <span class="whitespace-nowrap">Pas pour dépanner.</span>
          </p>
          <p class="text-lg text-foreground-muted mb-8 leading-relaxed">
            Je ne viens pas avec une recette magique. Juste de la curiosité, de la remise en question, et l'envie de solutionner au mieux les problèmes qu'on me confie.
          </p>
          <div class="flex flex-wrap justify-center md:justify-start gap-4 mb-8">
            <a
              href="/contact"
              title="Me contacter"
              class="btn-primary"
            >
              Discutons de ton besoin
            </a>
            <a
              href="#services"
              class="btn-outline"
            >
              Voir les services
            </a>
          </div>
          <div class="flex flex-wrap justify-center md:justify-start gap-2">
            {expertise.map(tech => (
              <span class="px-3 py-1 bg-surface-muted text-foreground rounded-full text-sm">{tech}</span>
            ))}
          </div>
        </div>
        <div class="md:col-span-2 flex flex-col items-center">
          <div class="w-64 h-64 md:w-80 md:h-80 rounded-full overflow-hidden border-4 border-border-light mb-4">
            <img
              class="w-full h-full object-cover"
              src="/fabiensalles.webp"
              alt="Fabien Salles"
              width="1024"
              height="768"
            />
          </div>
          <div class="flex flex-wrap justify-center gap-2">
            <span class="badge-status">✓ Freelance</span>
            <span class="badge-status">✓ Disponible</span>
            <span class="px-3 py-1 bg-surface-muted text-foreground rounded-full text-sm inline-flex items-center gap-1"><Icon name="mdi:map-marker" class="w-4 h-4" /> Paris — Full remote ou hybride</span>
          </div>
        </div>
      </div>
    </div>
  </section>


  <!-- SECTION PAIN POINTS -->
  <section class="py-12 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-2xl mx-auto text-center">
        <h2 class="text-2xl md:text-3xl font-bold mb-2">Ces situations te parlent ?</h2>
        <p class="text-foreground-muted mb-8">(Ou celles de ton client, de tes collègues, de tes équipes...)</p>

        <div class="space-y-3 mb-8 text-left inline-block">
          <div class="flex items-center gap-3 text-lg">
            <Icon name="mdi:delete-outline" class="w-6 h-6 text-primary flex-shrink-0" />
            <span>Du code <strong>jetable</strong> au lieu de <span class="text-foreground-muted">→</span> <strong class="text-primary">durable</strong></span>
          </div>
          <div class="flex items-center gap-3 text-lg">
            <Icon name="mdi:timer-sand" class="w-6 h-6 text-primary flex-shrink-0" />
            <span>Des livraisons <strong>tardives</strong> au lieu d'être <span class="text-foreground-muted">→</span> <strong class="text-primary">itératives</strong></span>
          </div>
          <div class="flex items-center gap-3 text-lg">
            <Icon name="mdi:weather-fog" class="w-6 h-6 text-primary flex-shrink-0" />
            <span>Des incompréhensions <strong>métier</strong> au lieu d'une <span class="text-foreground-muted">→</span> <strong class="text-primary">vision partagée</strong></span>
          </div>
          <div class="flex items-center gap-3 text-lg">
            <Icon name="mdi:flask" class="w-6 h-6 text-primary flex-shrink-0" />
            <span>Des tests <strong>fragiles</strong> au lieu d'être <span class="text-foreground-muted">→</span> <strong class="text-primary">utiles</strong></span>
          </div>
        </div>

        <p class="text-lg">
          Transformer ces freins en leviers, <strong class="text-primary">c'est possible.</strong>
        </p>
      </div>
    </div>
  </section>

  <!-- TRANSITION VERS SERVICES -->
  <section class="py-12">
    <div class="container mx-auto px-4">
      <div class="text-center">
        <h2 class="text-3xl md:text-4xl font-bold text-foreground-heading mb-6">Comment puis-je t'aider ?</h2>
        <p class="text-foreground-muted">
          Tu es
          <a href="#audit" title="Voir le service Audit" class="text-primary font-semibold hover:underline">CTO / Tech Lead</a> ?
          <a href="#accompagnement" title="Voir le service Accompagnement" class="text-primary font-semibold hover:underline">Recruteur / ESN</a> ?
          <a href="#formation" title="Voir le service Formation" class="text-primary font-semibold hover:underline">Responsable formation</a> ?
          <a href="#freelance" title="Voir l'apport d'affaires" class="text-primary font-semibold hover:underline">Freelance</a> ?
        </p>
      </div>
    </div>
  </section>

  <!-- SERVICE 1: AUDIT (Style A : fond blanc, carte grise) -->
  <section id="audit" class="py-16 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-5xl mx-auto">
        <div class="grid md:grid-cols-12 gap-0">
          <!-- Colonne gauche : titre + preuve sociale -->
          <div class="md:col-span-4 md:border-r md:border-border md:pr-8">
            <div class="md:sticky md:top-16">
              <h3 class="text-2xl md:text-3xl font-bold text-foreground-heading flex items-center gap-3 mb-6">
                <span>Auditer</span>
                <Icon name="mdi:magnify" class="w-8 h-8 text-primary" />
              </h3>

              <!-- Chiffre clé -->
              <div class="mb-6 p-4 bg-surface rounded-lg border border-border-light">
                <div class="text-3xl font-bold text-primary">10+</div>
                <div class="text-sm text-foreground-muted">applications auditées</div>
              </div>

              <!-- Expertise -->
              <div class="mb-6">
                <p class="text-xs text-foreground-muted uppercase tracking-wider mb-3">Expertise</p>
                <div class="flex flex-wrap gap-2">
                  <span class="px-2 py-1 bg-surface-muted rounded text-sm text-foreground-muted">PHP</span>
                  <span class="px-2 py-1 bg-surface-muted rounded text-sm text-foreground-muted">Symfony</span>
                  <span class="px-2 py-1 bg-surface-muted rounded text-sm text-foreground-muted">Legacy</span>
                  <span class="px-2 py-1 bg-surface-muted rounded text-sm text-foreground-muted">Frontend</span>
                  <span class="px-2 py-1 bg-surface-muted rounded text-sm text-foreground-muted">Architecture</span>
                  <span class="px-2 py-1 bg-surface-muted rounded text-sm text-foreground-muted">Sécurité</span>
                  <span class="px-2 py-1 bg-surface-muted rounded text-sm text-foreground-muted">API</span>
                  <span class="px-2 py-1 bg-surface-muted rounded text-sm text-foreground-muted">Testabilité</span>
                </div>
              </div>

              <!-- Logos clients -->
              <div class="mb-6">
                <p class="text-xs text-foreground-muted uppercase tracking-wider mb-3">Audité pour</p>
                <a href="/clients" title="Voir tous les clients" class="flex flex-wrap items-center hover:opacity-80 transition-opacity">
                  <img src="/images/clients/clever-age.webp" alt="Clever Age" class="h-8 max-w-[100px] object-contain grayscale opacity-70 hover:grayscale-0 hover:opacity-100 transition-all" width="769" height="537" />
                  <img src="/images/clients/cast.webp" alt="Cast" class="h-8 max-w-[100px] object-contain grayscale opacity-70 hover:grayscale-0 hover:opacity-100 transition-all" width="592" height="231" />
                  <img src="/images/clients/plum-kitchen.webp" alt="Plum Kitchen" class="h-8 max-w-[100px] object-contain grayscale opacity-70 hover:grayscale-0 hover:opacity-100 transition-all" width="1000" height="476" />
                </a>
              </div>

              <!-- Recommandation -->
              <a href="/recommendations" title="Voir toutes les recommandations" class="block bg-surface rounded-lg p-3 hover:bg-white transition-colors -mx-2">
                <blockquote class="text-sm border-l-2 border-primary pl-3">
                  <p class="text-foreground-muted italic mb-2">« Le client était très satisfait. Un grand merci pour ton étude. »</p>
                  <footer class="text-xs text-foreground-muted">— Retour client, février 2026</footer>
                </blockquote>
              </a>
            </div>
          </div>

          <!-- Colonne droite : contenu -->
          <div class="md:col-span-8 md:pl-8 mt-8 md:mt-0">
            <div class="bg-surface rounded-xl p-6 md:p-8 border border-border-light">
              <p class="text-xl md:text-2xl text-foreground-heading font-semibold mb-4 leading-relaxed">
                Tu reprends un projet et tu te demandes dans quoi tu mets les pieds ?<br>
                Tu as des doutes sur la qualité du code ?
              </p>

              <p class="text-foreground-muted mb-6 leading-relaxed text-lg">
                Je plonge dans le code, je regarde ce qui tient et ce qui va poser problème. PHP, frameworks maison ou standards : Symfony, Sylius, legacy sans framework, ou même des stacks plus anciennes.
              </p>

              <ul class="space-y-3 text-foreground mb-6">
                <li class="flex items-start gap-3 text-lg">
                  <span class="text-primary mt-0.5 text-xl">✓</span>
                  <span>Évaluation de la dette technique</span>
                </li>
                <li class="flex items-start gap-3 text-lg">
                  <span class="text-primary mt-0.5 text-xl">✓</span>
                  <span>Analyse de l'architecture, pratiques de développement</span>
                </li>
                <li class="flex items-start gap-3 text-lg">
                  <span class="text-primary mt-0.5 text-xl">✓</span>
                  <span>Rapport détaillé + plan d'action</span>
                </li>
              </ul>

              <blockquote class="border-l-4 border-primary pl-4 py-3 mb-6 bg-white rounded-r-lg">
                <p class="text-foreground italic">« Ce que j'aime dans l'audit : c'est souvent là que je vois des problèmes que personne n'avait encore identifiés. »</p>
              </blockquote>

              <a
                href="/audit"
                title="Auditer votre application"
                class="btn-primary text-lg"
              >
                En savoir plus →
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICE 2: ACCOMPAGNEMENT -->
  <section id="accompagnement" class="py-16">
    <div class="container mx-auto px-4">
      <div class="max-w-5xl mx-auto">
        <div class="grid md:grid-cols-12 gap-0">
          <!-- Colonne gauche : titre + preuve sociale -->
          <div class="md:col-span-4 md:border-r md:border-border md:pr-8">
            <div class="md:sticky md:top-16">
              <h3 class="text-2xl md:text-3xl font-bold text-foreground-heading flex items-center gap-3 mb-6">
                <span>Accompagner</span>
                <Icon name="mdi:crosshairs-gps" class="w-8 h-8 text-primary" />
              </h3>

              <!-- Chiffres clés -->
              <div class="flex gap-3 mb-6">
                <div class="flex-1 p-4 bg-white rounded-lg border border-border-light">
                  <div class="text-3xl font-bold text-primary">15+</div>
                  <div class="text-sm text-foreground-muted">années</div>
                </div>
                <div class="flex-1 p-4 bg-white rounded-lg border border-border-light">
                  <div class="text-3xl font-bold text-primary">26+</div>
                  <div class="text-sm text-foreground-muted">projets</div>
                </div>
              </div>

              <!-- Expertise -->
              <div class="mb-6">
                <p class="text-xs text-foreground-muted uppercase tracking-wider mb-3">Expertise</p>
                <div class="flex flex-wrap gap-2">
                  <span class="px-2 py-1 bg-white rounded text-sm text-foreground-muted">DDD</span>
                  <span class="px-2 py-1 bg-white rounded text-sm text-foreground-muted">TDD</span>
                  <span class="px-2 py-1 bg-white rounded text-sm text-foreground-muted">Agile</span>
                  <span class="px-2 py-1 bg-white rounded text-sm text-foreground-muted">PHP</span>
                  <span class="px-2 py-1 bg-white rounded text-sm text-foreground-muted">Symfony</span>
                  <span class="px-2 py-1 bg-white rounded text-sm text-foreground-muted">Sylius</span>
                  <span class="px-2 py-1 bg-white rounded text-sm text-foreground-muted">NodeJS</span>
                  <span class="px-2 py-1 bg-white rounded text-sm text-foreground-muted">TypeScript</span>
                  <span class="px-2 py-1 bg-white rounded text-sm text-foreground-muted">React</span>
                </div>
              </div>

              <!-- Logos clients -->
              <div class="mb-6">
                <p class="text-xs text-foreground-muted uppercase tracking-wider mb-3">Accompagné</p>
                <a href="/clients" title="Voir tous les clients" class="flex flex-wrap items-center gap-1 hover:opacity-80 transition-opacity">
                  <img src="/images/clients/hermes.png" alt="Hermès" class="h-8 max-w-[100px] object-contain grayscale opacity-70 hover:grayscale-0 hover:opacity-100 transition-all" width="3840" height="2160" />
                  <img src="/images/clients/eres.png" alt="Eres" class="h-8 max-w-[100px] object-contain grayscale opacity-70 hover:grayscale-0 hover:opacity-100 transition-all" width="1318" height="325" />
                  <img src="/images/clients/lvmh.webp" alt="LVMH" class="h-8 max-w-[100px] object-contain grayscale opacity-70 hover:grayscale-0 hover:opacity-100 transition-all" width="2336" height="681" />
                  <img src="/images/clients/japan-experience.webp" alt="Japan Experience" class="h-8 max-w-[100px] object-contain grayscale opacity-70 hover:grayscale-0 hover:opacity-100 transition-all" width="2059" height="183" />
                  <img src="/images/clients/jardiland.webp" alt="Jardiland" class="h-8 max-w-[100px] object-contain grayscale opacity-70 hover:grayscale-0 hover:opacity-100 transition-all" width="320" height="118" />
                </a>
              </div>

              <!-- Recommandation -->
              <a href="/recommendations" title="Voir toutes les recommandations" class="block bg-white rounded-lg p-3 hover:bg-surface-muted transition-colors -mx-2">
                <blockquote class="text-sm border-l-2 border-primary pl-3">
                  <p class="text-foreground-muted italic mb-2">« Sa capacité à rester calme malgré la pression, son ouverture au dialogue. »</p>
                  <footer class="text-xs text-foreground-muted">— Jean-Yves C., Bedrock</footer>
                </blockquote>
              </a>
            </div>
          </div>

          <!-- Colonne droite : contenu -->
          <div class="md:col-span-8 md:pl-8 mt-8 md:mt-0">
            <div class="bg-white rounded-xl p-6 md:p-8 border border-border-light">
              <p class="text-xl md:text-2xl text-foreground-heading font-semibold mb-4 leading-relaxed">
                Ton équipe a besoin d'un regard extérieur ?<br>
                D'un renfort qui ne fait pas que coder ?
              </p>

              <p class="text-foreground-muted mb-6 leading-relaxed text-lg">
                J'interviens pour améliorer vos pratiques, réduire la dette technique et transmettre les bonnes méthodes.
              </p>

              <ul class="space-y-3 text-foreground mb-6">
                <li class="flex items-start gap-3 text-lg">
                  <span class="text-primary mt-0.5 text-xl">✓</span>
                  <span>Intervention en régie ou au forfait</span>
                </li>
                <li class="flex items-start gap-3 text-lg">
                  <span class="text-primary mt-0.5 text-xl">✓</span>
                  <span>Amélioration d'un legacy, Refonte progressive</span>
                </li>
                <li class="flex items-start gap-3 text-lg">
                  <span class="text-primary mt-0.5 text-xl">✓</span>
                  <span>Support et transfert de compétences</span>
                </li>
              </ul>

              <blockquote class="border-l-4 border-primary pl-4 py-3 mb-6 bg-white rounded-r-lg">
                <p class="text-foreground italic">« Ce que j'aime dans l'accompagnement : voir une équipe gagner en autonomie et en confiance sur son propre code. »</p>
              </blockquote>

              <a
                href="/accompagnement"
                title="Voir mon accompagnement"
                class="btn-primary text-lg"
              >
                En savoir plus →
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICE 3: FORMATION -->
  <section id="formation" class="py-16 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-5xl mx-auto">
        <div class="grid md:grid-cols-12 gap-0">
          <!-- Colonne gauche : titre + preuve sociale -->
          <div class="md:col-span-4 md:border-r md:border-border md:pr-8">
            <div class="md:sticky md:top-16">
              <h3 class="text-2xl md:text-3xl font-bold text-foreground-heading flex items-center gap-3 mb-6">
                <span>Former</span>
                <Icon name="mdi:school" class="w-8 h-8 text-primary" />
              </h3>

              <!-- Chiffres clés -->
              <div class="flex gap-3 mb-6">
                <div class="flex-1 p-4 bg-surface rounded-lg border border-border-light">
                  <div class="text-3xl font-bold text-primary">{formationStats.participants}+</div>
                  <div class="text-sm text-foreground-muted">développeurs</div>
                </div>
                <div class="flex-1 p-4 bg-surface rounded-lg border border-border-light">
                  <div class="text-3xl font-bold text-primary">{formationStats.sessions}+</div>
                  <div class="text-sm text-foreground-muted">sessions</div>
                </div>
              </div>

              <!-- Formations -->
              <div class="mb-6">
                <p class="text-xs text-foreground-muted uppercase tracking-wider mb-3">Formations</p>
                <div class="flex flex-wrap gap-2">
                  <a href="/formations/git" title="Formation Git avancé" class="inline-flex items-center px-3 py-1.5 bg-white rounded-lg border border-border-light text-sm text-foreground hover:border-primary transition-colors"><strong>Git</strong></a>
                  <a href="/formations/phpunit" title="Formation PHPUnit" class="inline-flex items-center px-3 py-1.5 bg-white rounded-lg border border-border-light text-sm text-foreground hover:border-primary transition-colors"><strong>PHPUnit</strong></a>
                  <a href="/formations/ddd" title="Formation Domain-Driven Design" class="inline-flex items-center px-3 py-1.5 bg-white rounded-lg border border-border-light text-sm text-foreground hover:border-primary transition-colors"><strong>DDD</strong></a>
                </div>
              </div>

              <!-- Logos clients -->
              <div class="mb-6">
                <p class="text-xs text-foreground-muted uppercase tracking-wider mb-3">Formé pour</p>
                <a href="/clients" title="Voir tous les clients" class="flex flex-wrap items-center hover:opacity-80 transition-opacity">
                  <img src="/images/clients/clever-age.webp" alt="Clever Age" class="h-8 max-w-[100px] object-contain grayscale opacity-70 hover:grayscale-0 hover:opacity-100 transition-all" width="769" height="537" />
                  <img src="/images/clients/orsys.webp" alt="Orsys" class="h-8 max-w-[100px] object-contain grayscale opacity-70 hover:grayscale-0 hover:opacity-100 transition-all" width="431" height="151" />
                  <img src="/images/clients/esgi.webp" alt="ESGI" class="h-8 max-w-[100px] object-contain grayscale opacity-70 hover:grayscale-0 hover:opacity-100 transition-all" width="300" height="300" />
                </a>
              </div>

              <!-- Recommandation -->
              <a href="/recommendations#formations" title="Voir toutes les recommandations formations" class="block bg-surface rounded-lg p-3 hover:bg-white transition-colors -mx-2">
                <blockquote class="text-sm border-l-2 border-primary pl-3">
                  <p class="text-foreground-muted italic mb-2">« Contenu très complet et intervenant pédagogue et patient. »</p>
                  <footer class="text-xs text-foreground-muted">— Sarah Z., évaluation formation Git</footer>
                </blockquote>
              </a>
            </div>
          </div>

          <!-- Colonne droite : contenu -->
          <div class="md:col-span-8 md:pl-8 mt-8 md:mt-0">
            <div class="bg-surface rounded-xl p-6 md:p-8 border border-border-light">
              <p class="text-xl md:text-2xl text-foreground-heading font-semibold mb-4 leading-relaxed">
                Tes devs codent.
                Mais est-ce qu'ils investissent leur énergie au bon endroit ?
              </p>

              <p class="text-foreground-muted mb-6 leading-relaxed text-lg">
                Au-delà des aspects techniques, mes formations visent à transformer le mindset : comprendre où investir pour un vrai gain, produire du code qui dure, et arrêter de perdre du temps sur ce qui n'apporte pas de valeur.
              </p>

              <ul class="space-y-3 text-foreground mb-6">
                <li class="flex items-start gap-3 text-lg">
                  <span class="text-primary mt-0.5 text-xl">✓</span>
                  <span>Formations intra-entreprise, distantiel</span>
                </li>
                <li class="flex items-start gap-3 text-lg">
                  <span class="text-primary mt-0.5 text-xl">✓</span>
                  <span>Organisme déclaré (NDA)</span>
                </li>
                <li class="flex items-start gap-3 text-lg">
                  <span class="text-primary mt-0.5 text-xl">✓</span>
                  <span>Depuis 2016</span>
                </li>
              </ul>

              <blockquote class="border-l-4 border-primary pl-4 py-3 mb-6 bg-white rounded-r-lg">
                <p class="text-foreground italic">« Ce que j'aime dans la formation : voir quelqu'un repartir avec une nouvelle façon de penser, pas juste une nouvelle technique. »</p>
              </blockquote>

              <a
                href="/formations"
                title="Voir toutes les formations"
                class="btn-primary text-lg"
              >
                Voir les formations →
              </a>
            </div>
          </div>
        </div>
      </div>
