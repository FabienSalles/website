  <!-- SERVICE 4: AUTOMATISATION -->
  <section id="automatisation" class="py-16">
    <div class="container mx-auto px-4">
      <div class="max-w-5xl mx-auto">
        <div class="grid md:grid-cols-12 gap-0">
          <!-- Colonne gauche : titre + preuve sociale -->
          <div class="md:col-span-4 md:border-r md:border-border md:pr-8">
            <div class="md:sticky md:top-16">
              <h3 class="text-2xl md:text-3xl font-bold text-foreground-heading flex items-center gap-3 mb-6">
                <span>Automatiser</span>
                <Icon name="mdi:robot" class="w-8 h-8 text-primary" />
              </h3>

              <!-- Chiffres clés -->
              <div class="flex gap-3 mb-6">
                <div class="flex-1 p-4 bg-white rounded-lg border border-border-light">
                  <div class="text-3xl font-bold text-primary">3+</div>
                  <div class="text-sm text-foreground-muted">années</div>
                </div>
                <div class="flex-1 p-4 bg-white rounded-lg border border-border-light">
                  <div class="text-3xl font-bold text-primary">IA</div>
                  <div class="text-sm text-foreground-muted">× Craft</div>
                </div>
              </div>

              <!-- Outils -->
              <div class="mb-6">
                <p class="text-xs text-foreground-muted uppercase tracking-wider mb-3">Outils maîtrisés</p>
                <div class="flex flex-wrap gap-2">
                  <span class="px-2 py-1 bg-white rounded text-sm text-foreground-muted">Claude Code</span>
                  <span class="px-2 py-1 bg-white rounded text-sm text-foreground-muted">MCP</span>
                  <span class="px-2 py-1 bg-white rounded text-sm text-foreground-muted">Skills</span>
                  <span class="px-2 py-1 bg-white rounded text-sm text-foreground-muted">Hooks</span>
                  <span class="px-2 py-1 bg-white rounded text-sm text-foreground-muted">Commands</span>
                  <span class="px-2 py-1 bg-white rounded text-sm text-foreground-muted">Plugins</span>
                  <span class="px-2 py-1 bg-white rounded text-sm text-foreground-muted">RAG</span>
                  <span class="px-2 py-1 bg-white rounded text-sm text-foreground-muted">n8n</span>
                  <span class="px-2 py-1 bg-white rounded text-sm text-foreground-muted">GitHub Copilot</span>
                </div>
              </div>
            </div>
          </div>

          <!-- Colonne droite : contenu -->
          <div class="md:col-span-8 md:pl-8 mt-8 md:mt-0">
            <div class="bg-white rounded-xl p-6 md:p-8 border border-border-light">
              <p class="text-xl md:text-2xl text-foreground-heading font-semibold mb-4 leading-relaxed">
                L'IA change notre façon de coder.
                Mais sans direction, elle amplifie les problèmes autant que les solutions.
              </p>

              <p class="text-foreground-muted mb-6 leading-relaxed text-lg">
                Je t'aide à intégrer les outils d'automatisation dans tes workflows pour gagner en productivité sans sacrifier la qualité.
              </p>

              <ul class="space-y-3 text-foreground mb-6">
                <li class="flex items-start gap-3 text-lg">
                  <span class="text-primary mt-0.5 text-xl">✓</span>
                  <span>Intégration Claude Code / agents IA</span>
                </li>
                <li class="flex items-start gap-3 text-lg">
                  <span class="text-primary mt-0.5 text-xl">✓</span>
                  <span>Workflows automatisés</span>
                </li>
                <li class="flex items-start gap-3 text-lg">
                  <span class="text-primary mt-0.5 text-xl">✓</span>
                  <span>Garde-fous qualité</span>
                </li>
              </ul>

              <blockquote class="border-l-4 border-primary pl-4 py-3 mb-6 bg-white rounded-r-lg">
                <p class="text-foreground italic">« Ce que j'aime dans l'automatisation : trouver le bon équilibre entre vitesse et garde-fous. Aller vite, mais pas droit dans le mur. »</p>
              </blockquote>

              <a
                href="/automatisation"
                title="Automatiser vos workflows"
                class="btn-primary text-lg"
              >
                En savoir plus →
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SECTION PARTENAIRES (Alex) -->
