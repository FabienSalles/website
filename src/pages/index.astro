---
import Layout from '../layouts/Layout.astro';
import generateUrl from "@utils/url";
import { getStats } from '../data/formations';

const description = "Expert DDD, TDD & Software Craftsmanship. Audit, accompagnement, formation. J'aide tes équipes à livrer sereinement avec des solutions pensées pour durer."

// Stats dynamiques depuis les données de formations
const formationStats = getStats();

const stats = [
  { number: "15+", label: "années d'expérience" },
  { number: "26+", label: "projets accompagnés" },
  { number: `${formationStats.participants}+`, label: "développeurs formés" },
  { number: `${formationStats.sessions}+`, label: "formations dispensées" }
];

const expertise = [
  "PHP",
  "Symfony",
  "TypeScript",
  "Node.js",
  "TDD",
  "Clean Code",
  "Architecture Hexagonale",
  "DDD",
  "Refactoring",
  "Craftsmanship",
  "IA & Automatisation"
];

const services = [
  {
    icon: "🔍",
    title: "Auditer",
    intro: "Tu reprends un projet et tu te demandes dans quoi tu mets les pieds ?<br />Tu as des doutes sur la qualité du code avant d'investir ?",
    description: "Je plonge dans le code, je regarde ce qui tient et ce qui va poser problème. PHP, frameworks maison ou standards — Symfony, Sylius, legacy sans framework, ou même des stacks plus anciennes.",
    benefits: [
      "Évaluation de la dette technique",
      "Analyse de l'architecture, pratiques de développement",
      "Rapport détaillé + plan d'action"
    ],
    love: "Ce que j'aime dans l'audit : c'est souvent là que je vois des problèmes que personne n'avait encore identifiés.",
    cta: "En savoir plus",
    href: "/audit"
  },
  {
    icon: "🎯",
    title: "Accompagner",
    intro: "Ton équipe a besoin d'un regard extérieur ?<br />D'un renfort qui ne fait pas que coder, mais qui transmet ?",
    description: "J'interviens pour améliorer vos pratiques, réduire la dette technique et transmettre les bonnes méthodes.",
    benefits: [
      "Intervention en régie ou au forfait",
      "Amélioration d'un legacy, Refonte progressive",
      "Support et transfert de compétences"
    ],
    love: "Ce que j'aime dans l'accompagnement : voir une équipe gagner en autonomie et en confiance sur son propre code.",
    cta: "En savoir plus",
    href: "/accompagnement"
  },
  {
    icon: "🎓",
    title: "Former",
    intro: "Tes devs codent.<br />Mais est-ce qu'ils investissent leur énergie au bon endroit ?",
    description: "Au-delà des aspects techniques, mes formations visent à transformer le mindset : comprendre où investir pour un vrai gain, produire du code qui dure, et arrêter de perdre du temps sur ce qui n'apporte pas de valeur.",
    benefits: [
      "Formations intra-entreprise, distantiel",
      "Organisme déclaré (NDA)",
      `${formationStats.participants}+ développeurs formés depuis 2016`
    ],
    love: "Ce que j'aime dans la formation : voir quelqu'un repartir avec une nouvelle façon de penser, pas juste une nouvelle technique.",
    cta: "Voir les formations",
    href: "/formations"
  },
  {
    icon: "🤖",
    title: "Automatiser",
    intro: "L'IA change notre façon de coder.<br />Mais sans direction, elle amplifie les problèmes autant que les solutions.",
    description: "Je t'aide à intégrer les outils d'automatisation dans tes workflows — pour gagner en productivité sans sacrifier la qualité.",
    benefits: [
      "Intégration Claude Code / agents IA",
      "Workflows automatisés",
      "Garde-fous qualité"
    ],
    love: "Ce que j'aime dans l'automatisation : trouver le bon équilibre entre vitesse et garde-fous. Aller vite, mais pas droit dans le mur.",
    cta: "En savoir plus",
    href: "/automatisation"
  }
];

const testimonials = [
  {
    name: "Shahbran Khan GHULAM",
    role: "Ingénieur QA, Hermès",
    content: "Fabien, c'est un vrai pro. Il est extrêmement compétent, toujours pertinent dans ses analyses et redoutablement efficace. Il sait prendre du recul, proposer des solutions intelligentes et faire avancer les choses.",
    image: "/images/recommendations/shahbran-khan-ghulam.webp"
  },
  {
    name: "Jean-Yves Camier",
    role: "DevOps Technical Lead, Bedrock Streaming",
    content: "Sa capacité à rester calme malgré la pression, son ouverture au dialogue, sa curiosité, son amour des choses bien faites font de lui un collaborateur particulièrement important.",
    image: "/images/recommendations/jean-yves-camier.jpg"
  },
  {
    name: "Rodolphe Huot",
    role: "Développeur Web, Hermès",
    content: "Expertise technique pointue dans le développement et le craftsmanship. Toujours force de proposition et à la recherche de l'excellence. Je recommande chaleureusement.",
    image: "/images/recommendations/rodolphe-huot.webp"
  }
];
---

<Layout title="Fabien Salles - Expert DDD, TDD & Software Craftsmanship" description={description}>

  <!-- HERO SECTION -->
  <section class="bg-gradient-to-b from-gray-50 to-white">
    <div class="container mx-auto px-4 py-20 md:py-28">
      <div class="grid md:grid-cols-5 gap-8 items-center">
        <div class="md:col-span-3">
          <p class="text-3xl md:text-4xl font-bold mb-2 leading-tight">
            Salut, je suis Fabien.
          </p>
          <div class="text-orange-700 font-semibold mb-6 flex flex-wrap items-baseline gap-x-2">
            <span>15+ ans d'expérience</span>
            <span>·</span>
            <h1 class="inline text-orange-700 font-semibold text-base md:text-lg">DDD · TDD · Software Craftsmanship</h1>
          </div>
          <p class="text-xl text-gray-800 font-medium mb-6 leading-relaxed">
            J'aide tes équipes à livrer sereinement, avec des solutions pensées pour durer. <span class="text-gray-600 whitespace-nowrap">Pas pour dépanner.</span>
          </p>
          <p class="text-lg text-gray-600 mb-8 leading-relaxed">
            Je ne viens pas avec une recette magique. Juste de la curiosité, de la remise en question, et l'envie de solutionner au mieux les problèmes qu'on me confie.
          </p>
          <div class="flex flex-wrap gap-4 mb-8">
            <a
              href="/contact"
              class="inline-block bg-orange-700 text-white px-6 py-3 rounded-lg font-semibold hover:bg-orange-800 transition-colors"
            >
              Discutons de ton besoin
            </a>
            <a
              href="#services"
              class="inline-block border-2 border-orange-700 text-orange-700 px-6 py-3 rounded-lg font-semibold hover:bg-orange-50 transition-colors"
            >
              Voir les services
            </a>
          </div>
          <div class="flex flex-wrap gap-2">
            {expertise.map(tech => (
              <span class="px-3 py-1 bg-gray-100 text-gray-700 rounded-full text-sm">{tech}</span>
            ))}
          </div>
        </div>
        <div class="md:col-span-2 text-center md:text-right">
          <!-- Statut -->
          <div class="flex flex-wrap justify-center md:justify-end gap-2 mb-4">
            <span class="px-3 py-1 bg-green-100 text-green-800 rounded-full text-sm font-medium">✓ Freelance</span>
            <span class="px-3 py-1 bg-green-100 text-green-800 rounded-full text-sm font-medium">✓ Disponible</span>
            <span class="px-3 py-1 bg-gray-100 text-gray-700 rounded-full text-sm">📍 Paris — Full remote ou hybride</span>
          </div>
          <div class="relative h-80 md:h-96 mx-auto md:ml-auto md:mr-0 overflow-hidden rounded-lg">
            <img
              class="w-full h-full object-cover"
              src="/fabiensalles.jpg"
              alt="Fabien Salles"
              width="1024"
              height="768"
            />
            <div class="absolute inset-y-0 left-0 w-32 bg-gradient-to-r from-white to-transparent"></div>
            <div class="absolute inset-y-0 right-0 w-32 bg-gradient-to-l from-white to-transparent"></div>
            <div class="absolute inset-x-0 top-0 h-3 bg-gradient-to-b from-white to-transparent"></div>
            <div class="absolute inset-x-0 bottom-0 h-3 bg-gradient-to-t from-white to-transparent"></div>
          </div>
        </div>
      </div>
    </div>
  </section>


  <!-- SECTION PAIN POINTS -->
  <section class="py-12 bg-gray-50 border-t border-gray-200">
    <div class="container mx-auto px-4">
      <div class="max-w-2xl mx-auto text-center">
        <h2 class="text-2xl md:text-3xl font-bold mb-2">Ces situations te parlent ?</h2>
        <p class="text-gray-600 mb-8">(Ou celles de ton client, de tes collègues, de tes équipes...)</p>

        <div class="space-y-3 mb-8 text-left inline-block">
          <div class="flex items-center gap-3 text-lg">
            <span class="text-xl">🗑️</span>
            <span>Du code <strong>jetable</strong> au lieu de <span class="text-gray-400">→</span> <strong class="text-orange-700">durable</strong></span>
          </div>
          <div class="flex items-center gap-3 text-lg">
            <span class="text-xl">🐌</span>
            <span>Des livraisons <strong>tardives</strong> au lieu d'être <span class="text-gray-400">→</span> <strong class="text-orange-700">itératives</strong></span>
          </div>
          <div class="flex items-center gap-3 text-lg">
            <span class="text-xl">🌫️</span>
            <span>Des incompréhensions <strong>métier</strong> au lieu d'une <span class="text-gray-400">→</span> <strong class="text-orange-700">vision partagée</strong></span>
          </div>
          <div class="flex items-center gap-3 text-lg">
            <span class="text-xl">🧪</span>
            <span>Des tests <strong>fragiles</strong> au lieu d'être <span class="text-gray-400">→</span> <strong class="text-orange-700">utiles</strong></span>
          </div>
        </div>

        <p class="text-lg">
          Transformer ces freins en leviers, <strong class="text-orange-700">c'est possible.</strong>
        </p>
      </div>
    </div>
  </section>

  <!-- TRANSITION VERS SERVICES -->
  <section class="py-12 bg-gradient-to-br from-orange-900 to-orange-800">
    <div class="container mx-auto px-4">
      <div class="text-center">
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-6">Comment puis-je t'aider ?</h2>
        <p class="text-orange-100">
          Tu es
          <a href="#audit" class="text-white font-semibold hover:underline">CTO / Tech Lead</a> ?
          <a href="#accompagnement" class="text-white font-semibold hover:underline">Recruteur / ESN</a> ?
          <a href="#formation" class="text-white font-semibold hover:underline">Responsable formation</a> ?
          <a href="#freelance" class="text-white font-semibold hover:underline">Freelance</a> ?
        </p>
      </div>
    </div>
  </section>

  <!-- SERVICE 1: AUDIT (Style A : fond blanc, carte grise) -->
  <section id="audit" class="py-16 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-5xl mx-auto">
        <div class="grid md:grid-cols-12 gap-0">
          <!-- Colonne gauche : titre + preuve sociale -->
          <div class="md:col-span-4 md:border-r md:border-gray-200 md:pr-8">
            <div class="md:sticky md:top-16">
              <h3 class="text-2xl md:text-3xl font-bold text-gray-900 flex items-center gap-3 mb-6">
                <span>Auditer</span>
                <span class="text-3xl">🔍</span>
              </h3>

              <!-- Chiffre clé -->
              <div class="mb-6 p-4 bg-orange-50 rounded-lg border border-orange-100">
                <div class="text-3xl font-bold text-orange-700">10+</div>
                <div class="text-sm text-gray-600">applications auditées</div>
              </div>

              <!-- Expertise -->
              <div class="mb-6">
                <p class="text-xs text-gray-500 uppercase tracking-wider mb-3">Expertise</p>
                <div class="flex flex-wrap gap-2">
                  <span class="px-2 py-1 bg-orange-100 rounded text-sm text-orange-800">PHP</span>
                  <span class="px-2 py-1 bg-orange-100 rounded text-sm text-orange-800">Symfony</span>
                  <span class="px-2 py-1 bg-orange-100 rounded text-sm text-orange-800">Legacy</span>
                  <span class="px-2 py-1 bg-orange-100 rounded text-sm text-orange-800">Frontend</span>
                  <span class="px-2 py-1 bg-orange-100 rounded text-sm text-orange-800">Architecture</span>
                  <span class="px-2 py-1 bg-orange-100 rounded text-sm text-orange-800">Sécurité</span>
                  <span class="px-2 py-1 bg-orange-100 rounded text-sm text-orange-800">API</span>
                  <span class="px-2 py-1 bg-orange-100 rounded text-sm text-orange-800">Testabilité</span>
                </div>
              </div>

              <!-- Logos clients -->
              <div class="mb-6">
                <p class="text-xs text-gray-500 uppercase tracking-wider mb-3">Audité pour</p>
                <a href="/clients" class="flex flex-wrap items-center gap-4 hover:opacity-80 transition-opacity">
                  <img src="/images/clients/clever-age.webp" alt="Clever Age" class="h-8 grayscale opacity-70 hover:grayscale-0 hover:opacity-100 transition-all" width="769" height="537" />
                  <img src="/images/clients/cast.webp" alt="Cast" class="h-8 grayscale opacity-70 hover:grayscale-0 hover:opacity-100 transition-all" width="592" height="231" />
                  <img src="/images/clients/plum-kitchen.webp" alt="Plum Kitchen" class="h-8 grayscale opacity-70 hover:grayscale-0 hover:opacity-100 transition-all" width="1000" height="476" />
                </a>
              </div>

              <!-- Recommandation -->
              <a href="/recommendations" class="block hover:bg-gray-50 rounded-lg transition-colors -mx-2 px-2 py-2">
                <blockquote class="text-sm border-l-2 border-orange-300 pl-3">
                  <p class="text-gray-600 italic mb-2">« Le client était très satisfait. Un grand merci pour ton étude. »</p>
                  <footer class="text-xs text-gray-500">— Retour client, février 2026</footer>
                </blockquote>
              </a>
            </div>
          </div>

          <!-- Colonne droite : contenu -->
          <div class="md:col-span-8 md:pl-8 mt-8 md:mt-0">
            <div class="bg-gray-50 rounded-xl p-6 md:p-8 border border-gray-100">
              <p class="text-xl md:text-2xl text-gray-900 font-semibold mb-4 leading-relaxed">
                Tu reprends un projet et tu te demandes dans quoi tu mets les pieds ?
                Tu as des doutes sur la qualité du code avant d'investir ?
              </p>

              <p class="text-gray-600 mb-6 leading-relaxed text-lg">
                Je plonge dans le code, je regarde ce qui tient et ce qui va poser problème. PHP, frameworks maison ou standards — Symfony, Sylius, legacy sans framework, ou même des stacks plus anciennes.
              </p>

              <ul class="space-y-3 text-gray-700 mb-6">
                <li class="flex items-start gap-3 text-lg">
                  <span class="text-orange-600 mt-0.5 text-xl">✓</span>
                  <span>Évaluation de la dette technique</span>
                </li>
                <li class="flex items-start gap-3 text-lg">
                  <span class="text-orange-600 mt-0.5 text-xl">✓</span>
                  <span>Analyse de l'architecture, pratiques de développement</span>
                </li>
                <li class="flex items-start gap-3 text-lg">
                  <span class="text-orange-600 mt-0.5 text-xl">✓</span>
                  <span>Rapport détaillé + plan d'action</span>
                </li>
              </ul>

              <blockquote class="border-l-4 border-orange-300 pl-4 py-3 mb-6 bg-orange-50 rounded-r-lg">
                <p class="text-gray-700 italic">« Ce que j'aime dans l'audit : c'est souvent là que je vois des problèmes que personne n'avait encore identifiés. »</p>
              </blockquote>

              <a
                href="/audit"
                class="inline-block bg-orange-700 text-white px-6 py-3 rounded-lg font-semibold hover:bg-orange-800 transition-colors text-lg"
              >
                En savoir plus →
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICE 2: ACCOMPAGNEMENT (Style B : fond orange, carte blanche) -->
  <section id="accompagnement" class="py-16 bg-orange-900">
    <div class="container mx-auto px-4">
      <div class="max-w-5xl mx-auto">
        <div class="grid md:grid-cols-12 gap-0">
          <!-- Colonne gauche : titre + preuve sociale -->
          <div class="md:col-span-4 md:border-r md:border-white/20 md:pr-8">
            <div class="md:sticky md:top-16">
              <h3 class="text-2xl md:text-3xl font-bold text-white flex items-center gap-3 mb-6">
                <span>Accompagner</span>
                <span class="text-3xl">🎯</span>
              </h3>

              <!-- Chiffres clés -->
              <div class="flex gap-3 mb-6">
                <div class="flex-1 p-4 bg-white/15 rounded-lg backdrop-blur-sm">
                  <div class="text-3xl font-bold text-white">15+</div>
                  <div class="text-sm text-orange-100">années</div>
                </div>
                <div class="flex-1 p-4 bg-white/15 rounded-lg backdrop-blur-sm">
                  <div class="text-3xl font-bold text-white">26+</div>
                  <div class="text-sm text-orange-100">projets</div>
                </div>
              </div>

              <!-- Expertise -->
              <div class="mb-6">
                <p class="text-xs text-orange-200 uppercase tracking-wider mb-3">Expertise</p>
                <div class="flex flex-wrap gap-2">
                  <span class="px-2 py-1 bg-white/15 rounded text-sm text-white">DDD</span>
                  <span class="px-2 py-1 bg-white/15 rounded text-sm text-white">TDD</span>
                  <span class="px-2 py-1 bg-white/15 rounded text-sm text-white">Agile</span>
                  <span class="px-2 py-1 bg-white/15 rounded text-sm text-white">PHP</span>
                  <span class="px-2 py-1 bg-white/15 rounded text-sm text-white">Symfony</span>
                  <span class="px-2 py-1 bg-white/15 rounded text-sm text-white">Sylius</span>
                  <span class="px-2 py-1 bg-white/15 rounded text-sm text-white">NodeJS</span>
                  <span class="px-2 py-1 bg-white/15 rounded text-sm text-white">TypeScript</span>
                  <span class="px-2 py-1 bg-white/15 rounded text-sm text-white">React</span>
                </div>
              </div>

              <!-- Logos clients -->
              <div class="mb-6">
                <p class="text-xs text-orange-200 uppercase tracking-wider mb-3">Accompagné</p>
                <a href="/clients" class="flex flex-wrap items-center gap-4 hover:opacity-80 transition-opacity">
                  <img src="/images/clients/hermes.png" alt="Hermès" class="h-5 brightness-0 invert opacity-70 hover:opacity-100 transition-all" width="3840" height="2160" />
                  <img src="/images/clients/eres.png" alt="Eres" class="h-5 brightness-0 invert opacity-70 hover:opacity-100 transition-all" width="1318" height="325" />
                  <img src="/images/clients/lvmh.webp" alt="LVMH" class="h-5 brightness-0 invert opacity-70 hover:opacity-100 transition-all" width="2336" height="681" />
                  <img src="/images/clients/japan-experience.webp" alt="Japan Experience" class="h-5 brightness-0 invert opacity-70 hover:opacity-100 transition-all" width="2059" height="183" />
                  <img src="/images/clients/jardiland.webp" alt="Jardiland" class="h-5 brightness-0 invert opacity-70 hover:opacity-100 transition-all" width="320" height="118" />
                </a>
              </div>

              <!-- Recommandation -->
              <a href="/recommendations" class="block hover:bg-white/10 rounded-lg transition-colors -mx-2 px-2 py-2">
                <blockquote class="text-sm border-l-2 border-white/50 pl-3">
                  <p class="text-orange-100 italic mb-2">« Sa capacité à rester calme malgré la pression, son ouverture au dialogue. »</p>
                  <footer class="text-xs text-orange-200">— Jean-Yves C., Bedrock</footer>
                </blockquote>
              </a>
            </div>
          </div>

          <!-- Colonne droite : contenu -->
          <div class="md:col-span-8 md:pl-8 mt-8 md:mt-0">
            <div class="bg-white rounded-xl p-6 md:p-8 shadow-sm">
              <p class="text-xl md:text-2xl text-gray-900 font-semibold mb-4 leading-relaxed">
                Ton équipe a besoin d'un regard extérieur ?
                D'un renfort qui ne fait pas que coder, mais qui transmet ?
              </p>

              <p class="text-gray-600 mb-6 leading-relaxed text-lg">
                J'interviens pour améliorer vos pratiques, réduire la dette technique et transmettre les bonnes méthodes.
              </p>

              <ul class="space-y-3 text-gray-700 mb-6">
                <li class="flex items-start gap-3 text-lg">
                  <span class="text-orange-600 mt-0.5 text-xl">✓</span>
                  <span>Intervention en régie ou au forfait</span>
                </li>
                <li class="flex items-start gap-3 text-lg">
                  <span class="text-orange-600 mt-0.5 text-xl">✓</span>
                  <span>Amélioration d'un legacy, Refonte progressive</span>
                </li>
                <li class="flex items-start gap-3 text-lg">
                  <span class="text-orange-600 mt-0.5 text-xl">✓</span>
                  <span>Support et transfert de compétences</span>
                </li>
              </ul>

              <blockquote class="border-l-4 border-orange-300 pl-4 py-3 mb-6 bg-orange-50 rounded-r-lg">
                <p class="text-gray-700 italic">« Ce que j'aime dans l'accompagnement : voir une équipe gagner en autonomie et en confiance sur son propre code. »</p>
              </blockquote>

              <a
                href="/accompagnement"
                class="inline-block bg-orange-700 text-white px-6 py-3 rounded-lg font-semibold hover:bg-orange-800 transition-colors text-lg"
              >
                En savoir plus →
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICE 3: FORMATION -->
  <section id="formation" class="py-16 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-5xl mx-auto">
        <div class="grid md:grid-cols-12 gap-0">
          <!-- Colonne gauche : titre + preuve sociale -->
          <div class="md:col-span-4 md:border-r md:border-gray-200 md:pr-8">
            <div class="md:sticky md:top-16">
              <h3 class="text-2xl md:text-3xl font-bold text-gray-900 flex items-center gap-3 mb-6">
                <span>Former</span>
                <span class="text-3xl">🎓</span>
              </h3>

              <!-- Chiffres clés -->
              <div class="flex gap-3 mb-6">
                <div class="flex-1 p-4 bg-orange-50 rounded-lg border border-orange-100">
                  <div class="text-3xl font-bold text-orange-700">{formationStats.participants}+</div>
                  <div class="text-sm text-gray-600">développeurs</div>
                </div>
                <div class="flex-1 p-4 bg-orange-50 rounded-lg border border-orange-100">
                  <div class="text-3xl font-bold text-orange-700">{formationStats.sessions}+</div>
                  <div class="text-sm text-gray-600">sessions</div>
                </div>
              </div>

              <!-- Formations -->
              <div class="mb-6">
                <p class="text-xs text-gray-500 uppercase tracking-wider mb-3">Formations</p>
                <div class="flex flex-wrap gap-2">
                  <a href="/formations/git" class="px-2 py-1 bg-orange-100 hover:bg-orange-200 rounded text-sm text-orange-800 transition-colors">Git</a>
                  <a href="/formations/phpunit" class="px-2 py-1 bg-orange-100 hover:bg-orange-200 rounded text-sm text-orange-800 transition-colors">PHPUnit</a>
                  <a href="/formations/ddd" class="px-2 py-1 bg-orange-100 hover:bg-orange-200 rounded text-sm text-orange-800 transition-colors">DDD</a>
                </div>
              </div>

              <!-- Logos clients -->
              <div class="mb-6">
                <p class="text-xs text-gray-500 uppercase tracking-wider mb-3">Formé pour</p>
