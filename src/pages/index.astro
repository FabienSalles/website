                  <img src="/images/clients/clever-age.webp" alt="Clever Age" class="h-8 grayscale opacity-70 hover:grayscale-0 hover:opacity-100 transition-all" width="769" height="537" />
                  <img src="/images/clients/orsys.webp" alt="Orsys" class="h-8 grayscale opacity-70 hover:grayscale-0 hover:opacity-100 transition-all" width="431" height="151" />
                  <img src="/images/clients/esgi.webp" alt="ESGI" class="h-8 grayscale opacity-70 hover:grayscale-0 hover:opacity-100 transition-all" width="300" height="300" />
                </a>
              </div>

              <!-- Recommandation -->
              <a href="/recommendations#formations" class="block hover:bg-gray-50 rounded-lg transition-colors -mx-2 px-2 py-2">
                <blockquote class="text-sm border-l-2 border-orange-300 pl-3">
                  <p class="text-gray-600 italic mb-2">« Contenu très complet et intervenant pédagogue et patient. »</p>
                  <footer class="text-xs text-gray-500">— Sarah Z., évaluation formation Git</footer>
