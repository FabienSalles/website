---
import Layout from '../layouts/Layout.astro';
---

<Layout 
  title="Contactez-moi — Fabien Salles — Expert PHP & Craft"
  description="Contactez Fabien Salles pour une mission, un audit de code ou une formation PHP/Symfony. Expertise Craft, DDD, TDD. Disponible en remote ou hybride."
>
    <div class="container mx-auto px-4 py-12">
    <section class="text-center py-16">
      <h1 class="text-4xl md:text-5xl font-bold mb-6 leading-tight">
        Contactez-moi<br>
        <span class="text-orange-700">Mission, Audit, Formation & autres</span>
      </h1>
    </section>
    <div class="max-w-3xl mx-auto">

    <div class="prose prose-lg mb-12">
      <p>
        Vous souhaitez discuter de votre projet ou organiser une formation ? Je serai ravi d'en discuter avec vous.
      </p>
    </div>

    <form name="contact" class="space-y-8 max-w-2xl" data-netlify="true">
      <div class="grid md:grid-cols-2 gap-6">
        <div class="form-group">
          <label for="name" class="form-label">
            Nom complet *
          </label>
          <input
            type="text"
            id="name"
            name="name"
            required
            class="form-input"
            placeholder="Votre nom"
          />
        </div>

        <div class="form-group">
          <label for="email" class="form-label">
            Email *
          </label>
          <input
            type="email"
            id="email"
            name="email"
            required
            class="form-input"
            placeholder="votre@email.com"
          />
        </div>
      </div>

      <div class="form-group">
        <label for="subject" class="form-label">
          Sujet *
        </label>
        <select
          id="subject"
          name="subject"
          required
          class="form-select"
        >
          <option value="">Sélectionnez un sujet</option>
          <option value="accompagnement">Accompagnement</option>
          <option value="audit">Audit de code</option>
          <option value="formation">Formation</option>
          <option value="automatisation">Automatisation</option>
          <option value="autre">Autre</option>
        </select>
      </div>

      <div class="form-group">
        <label for="message" class="form-label">
          Message *
        </label>
        <textarea
          id="message"
          name="message"
          rows="6"
          required
          class="form-textarea"
          placeholder="Décrivez votre projet ou vos besoins..."
        ></textarea>
      </div>

      <button
        type="submit"
        class="w-full bg-orange-700 text-white py-4 px-8 rounded-lg font-medium
               hover:bg-orange-800 transition-colors duration-300
               focus:outline-none focus:ring-2 focus:ring-orange-500 focus:ring-offset-2"
      >
        Envoyer le message
      </button>
    </form>

    <div class="mt-12 pt-8 border-t">
      <h2 class="text-2xl font-bold mb-4">Autres moyens de contact</h2>
      <a
        href="https://www.linkedin.com/in/fabiensalles/"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center text-orange-700 hover:text-orange-800 transition-colors"
      >
        LinkedIn
      </a>
    </div>
  </div>
  </div>
</Layout>

<script>
  const params = new URLSearchParams(window.location.search);
  const subject = params.get('subject') || params.get('service');
  if (subject) {
    const select = document.getElementById('subject') as HTMLSelectElement;
    if (select) {
      select.value = subject;
    }
  }
</script>

<style>
  .form-group {
    @apply relative;
  }

  .form-label {
    @apply block text-sm font-medium text-gray-700 mb-1;
  }

  .form-input,
  .form-select,
  .form-textarea {
    @apply w-full px-4 py-3 rounded-lg border border-gray-200 
           focus:ring-2 focus:ring-orange-500 focus:border-orange-500
           transition-colors duration-300;
  }
</style>